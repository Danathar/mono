# Helper stage that exposes the shared scripts to later stages.
FROM scratch AS ctx

COPY shared/ /shared

# Debian unstable base image for both build and runtime stages.
FROM docker.io/library/debian:unstable AS debbase

# Builder stage: keep compilers and build dependencies out of the final image.
FROM debbase AS builder

# Install toolchain packages and ostree/dracut dependencies needed to build bootc.
RUN --mount=type=tmpfs,dst=/tmp --mount=type=tmpfs,dst=/root --mount=type=tmpfs,dst=/boot \
    apt update -y && \
    apt install -y git curl make build-essential go-md2man libzstd-dev pkgconf dracut libostree-dev ostree

# Rust is only needed while compiling, so keep its cache under `/tmp`.
ENV CARGO_HOME=/tmp/rust
ENV RUSTUP_HOME=/tmp/rust
WORKDIR /home/build
# Debian provides many dependencies, but rustup gives us a current Rust toolchain
# for building upstream bootc.
RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    curl --proto '=https' --tlsv1.2 -sSf "https://sh.rustup.rs" | sh -s -- --profile minimal -y && \
    sh -c ". ${RUSTUP_HOME}/env ; /ctx/shared/build.sh"

# Common pre-finalization stage for the Debian base image.
FROM debbase AS common
COPY --from=builder /output /

# Install core base packages inline so the Debian image tracks upstream's
# `systemd-boot*` package selection.
# The kernel is copied next to its module directory because later boot tooling
# expects to find `vmlinuz` there.
RUN --mount=type=tmpfs,dst=/tmp/apt-cache --mount=type=tmpfs,dst=/root --mount=type=tmpfs,dst=/boot \
    apt update -y && \
    apt install -y \
        btrfs-progs \
        curl \
        dbus \
        distrobox \
        dosfstools \
        dracut \
        e2fsprogs \
        fdisk \
        firewalld \
        firmware-linux-free \
        fwupd \
        git \
        iproute2 \
        libostree-dev \
        linux-image-generic \
        network-manager \
        ntfs-3g \
        openssh-server \
        podman \
        rsync \
        skopeo \
        smartmontools \
        sudo \
        systemd \
        systemd-boot* \
        vim \
        wget \
        xfsprogs && \
    cp /boot/vmlinuz-* "$(find /usr/lib/modules -maxdepth 1 -type d | tail -n 1)/vmlinuz" && \
    apt clean -y && \
    rm -rf /var/lib/apt/lists/*

# Generate an initramfs that contains the bootc boot logic.
RUN --mount=type=tmpfs,dst=/tmp --mount=type=tmpfs,dst=/root \
    --mount=type=bind,from=ctx,source=/,target=/ctx \
    /ctx/shared/initramfs.sh

# Final bootable operating-system image.
FROM common AS base

# Put future home directories under `/var/home`, then normalize the root
# filesystem to the immutable bootc layout.
RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    sed -i 's|^HOME=.*|HOME=/var/home|' "/etc/default/useradd" && \
    /ctx/shared/bootc-rootfs.sh

# Remove hardcoded root password and lock it for security.
RUN passwd -l root

# Network and basic services configuration.
RUN sed -i 's/^hosts: .*/hosts: files mdns_minimal [NOTFOUND=return] dns myhostname/' /etc/nsswitch.conf && \
    systemctl enable NetworkManager && \
    systemctl enable firewalld && \
    systemctl enable ssh

# Source profile.d scripts for non-login shells.
RUN echo -e '\n# Source profile.d scripts for non-login shells\nfor script in /etc/profile.d/*.sh; do\n  [ -r "$script" ] && . "$script"\ndone\nunset script' >> /etc/bash.bashrc

# OCI metadata consumed by bootc-aware tooling.
LABEL containers.bootc 1

# Validate the finished container before the build succeeds.
RUN bootc container lint

# Copy ublue-os/brew and enable its systemd services.
COPY --from=ghcr.io/ublue-os/brew:latest /system_files /
RUN systemctl preset brew-setup.service brew-update.timer brew-upgrade.timer
