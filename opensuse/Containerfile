# Helper stage that carries only the shared scripts.
FROM scratch AS ctx

COPY ../shared/ /shared

# Base openSUSE Tumbleweed filesystem.
FROM registry.opensuse.org/opensuse/tumbleweed:latest AS base

# Dedicated builder stage for compiling bootc.
FROM base AS builder

# Install compilers and libraries needed for the build.
RUN zypper install -y binutils cargo git go-md2man libostree-devel make rust

WORKDIR /home/build
# Reuse the shared build script so every distro compiles bootc the same way.
RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    /ctx/shared/build.sh

# Final bootable system image.
FROM base AS system

# Copy in the bootc artifacts from the builder stage.
COPY --from=builder /output /

# Install the kernel, firmware, filesystem tools, dracut, and runtime services
# that the final image needs to boot and manage itself.
RUN zypper install -y btrfs-progs cpio dosfstools dracut dracut e2fsprogs glib2 kernel-default kernel-firmware-all ostree skopeo systemd systemd-boot udev xfsprogs zstd libcrypto57

# Rebuild the initramfs with the bootc dracut module enabled.
RUN --mount=type=tmpfs,dst=/tmp --mount=type=tmpfs,dst=/root \
    --mount=type=bind,from=ctx,source=/,target=/ctx \
    /ctx/shared/initramfs.sh

# Send new users to `/var/home`, then convert the image to the bootc directory layout.
RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    echo "HOME=/var/home" | tee -a "/etc/default/useradd" && \
    /ctx/shared/bootc-rootfs.sh

# openSUSE may leave distro defaults in `/usr/etc`; removing them avoids conflicts
# with the final immutable image layout used by bootc.
RUN rm -rf /usr/etc

# OCI metadata marking this as a bootc-capable image.
LABEL containers.bootc 1

# Catch obvious layout or packaging mistakes while still in CI.
RUN bootc container lint
